{
  "buildCommand": "pnpm --filter @workspace/app run build && cp -r artifacts/app/dist/public dist",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": null,
  "build": {
    "env": {
      "BASE_PATH": "/",
      "PORT": "3000"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
