{
  "buildCommand": "pnpm --filter @workspace/app run build",
  "outputDirectory": "artifacts/app/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "build": {
    "env": {
      "BASE_PATH": "/",
      "PORT": "3000"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
